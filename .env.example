# Shared
APP_ENV=local
TZ=Asia/Tokyo

# Backend
BACKEND_CORS_ORIGINS=http://localhost:3000
DATABASE_URL=mysql+pymysql://kakeibo:kakeibo_password@localhost:3306/kakeibo
JWT_SECRET_KEY=change-me-in-local-env
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=5
COOKIE_SECURE=false
CSRF_TOKEN_EXPIRE_MINUTES=30
UPLOAD_STORAGE_ROOT=storage/uploads
MAX_UPLOAD_SIZE_MB=10

# MySQL
MYSQL_DATABASE=kakeibo
MYSQL_USER=kakeibo
MYSQL_PASSWORD=kakeibo_password
MYSQL_ROOT_PASSWORD=root_password

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
