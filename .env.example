# Shared
APP_ENV=local
TZ=Asia/Tokyo

# Backend
BACKEND_CORS_ORIGINS=http://localhost:3000
DATABASE_URL=mysql+pymysql://kakeibo:kakeibo_password@localhost:3306/kakeibo
JWT_SECRET_KEY=change-me-in-local-env-at-least-32-bytes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=5
COOKIE_SECURE=false
CSRF_TOKEN_EXPIRE_MINUTES=30
ADMIN_SETUP_TOKEN=change-me-before-bootstrap
UPLOAD_STORAGE_ROOT=storage/uploads
MAX_UPLOAD_SIZE_MB=10

# MySQL
MYSQL_DATABASE=kakeibo
MYSQL_USER=kakeibo
MYSQL_PASSWORD=kakeibo_password
MYSQL_ROOT_PASSWORD=root_password

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_AUTH_GUARD_ENABLED=false
AUTH_GUARD_ENABLED=false

# E2E
E2E_DATABASE_URL=mysql+pymysql://kakeibo:kakeibo_password@localhost:3306/kakeibo_e2e
E2E_ADMIN_DATABASE_URL=mysql+pymysql://root:root_password@localhost:3306/mysql
E2E_BASE_URL=http://127.0.0.1:3000
E2E_API_BASE_URL=http://127.0.0.1:8000
E2E_FRONTEND_PORT=3000
E2E_BACKEND_PORT=8000
E2E_JWT_SECRET_KEY=e2e-local-jwt-secret-key-with-at-least-32-bytes
