{
  "name": "kakeibo-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "setup": "npm run setup:backend && npm run setup:frontend",
    "setup:backend": "node scripts/backend.mjs setup",
    "setup:frontend": "npm --prefix frontend install",
    "migrate": "node scripts/backend.mjs migrate",
    "dev": "node scripts/dev.mjs",
    "dev:backend": "node scripts/backend.mjs dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "test:backend": "node scripts/backend.mjs test",
    "test:frontend": "npm --prefix frontend run typecheck && npm --prefix frontend run test:pages",
    "build:frontend": "npm --prefix frontend run build",
    "test:e2e": "npm --prefix frontend run test:e2e"
  }
}
